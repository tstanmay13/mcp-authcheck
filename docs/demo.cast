[8.22,"o","\r\n\u001b[1mmcp-authcheck\u001b[0m \u001b[2mv0.1.0 · spec 2026-07-28\u001b[0m\r\n\u001b[2mtarget\u001b[0m  https://mcp.deepwiki.com/mcp\r\n\r\n  \u001b[34m\u001b[1m  N/A  \u001b[0m\u001b[0m  \u001b[34mpublic server — no authorization enforced; auth conformance not applicable\u001b[0m\r\n\r\n  \u001b[34mℹ\u001b[0m \u001b[2mA1       \u001b[0m \u001b[31mCRITICAL\u001b[0m Rejects unauthenticated requests with 401\r\n      \u001b[2mserver returns results to unauthenticated callers — it appears to be public (no authorization). The auth-conformance checks below do not apply.\u001b[0m\r\n  \u001b[33m▲\u001b[0m \u001b[2mE1       \u001b[0m \u001b[90mLOW     \u001b[0m Validates Origin header (DNS-rebinding defense)\r\n      \u001b[2mforeign Origin got 200 — no Origin validation observed (low risk for a remote server; matters most for locally-bound servers)\u001b[0m\r\n      \u001b[36mfix:\u001b[0m If this server can be reached from a browser, validate the Origin header and reject unrecognized origins.\r\n  \u001b[34mℹ\u001b[0m \u001b[2mE2       \u001b[0m \u001b[90mLOW     \u001b[0m Rejects GET on the MCP endpoint (2026-07-28)\r\n      \u001b[2mGET returned 400 — 2026-07-28 removed the GET stream, so 405 is expected\u001b[0m\r\n\r\n  \u001b[32m0 pass\u001b[0m\u001b[2m · \u001b[0m\u001b[2m0 fail\u001b[0m\u001b[2m · \u001b[0m\u001b[33m1 warn\u001b[0m\u001b[2m · \u001b[0m\u001b[90m8 skip\u001b[0m\u001b[2m · \u001b[0m\u001b[2m0 error\u001b[0m\r\n"]
