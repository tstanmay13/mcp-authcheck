[5.06,"o","\r\n\u001b[1mmcp-authcheck\u001b[0m \u001b[2mv0.1.0 · spec 2026-07-28\u001b[0m\r\n\u001b[2mtarget\u001b[0m  https://mcp.intercom.com/mcp\r\n\r\n  \u001b[31m\u001b[1m  F  \u001b[0m\u001b[0m  \u001b[1m37/100\u001b[0m  \u001b[31mcapped by critical failure: A2\u001b[0m\r\n\r\n  \u001b[32m✔\u001b[0m \u001b[2mA1       \u001b[0m \u001b[31mCRITICAL\u001b[0m Rejects unauthenticated requests with 401\r\n      \u001b[2mserver challenges unauthenticated requests (via initialize)\u001b[0m\r\n  \u001b[31m✘\u001b[0m \u001b[2mA2       \u001b[0m \u001b[31mCRITICAL\u001b[0m 401 challenge advertises resource_metadata (RFC 9728 §5.1)\r\n      \u001b[2ma Bearer challenge is present but omits resource_metadata, and no PRM is served — clients cannot discover authorization\u001b[0m\r\n      \u001b[36mfix:\u001b[0m Add resource_metadata=\"<PRM URL>\" to the 401 Bearer challenge.\r\n  \u001b[31m✘\u001b[0m \u001b[2mB1       \u001b[0m \u001b[31mCRITICAL\u001b[0m Protected Resource Metadata endpoint served\r\n      \u001b[2mno Protected Resource Metadata document found at the advertised or well-known URL\u001b[0m\r\n      \u001b[36mfix:\u001b[0m Serve RFC 9728 metadata (200 application/json) at /.well-known/oauth-protected-resource.\r\n  \u001b[33m▲\u001b[0m \u001b[2mD1       \u001b[0m \u001b[34mMEDIUM  \u001b[0m Validates access tokens (rejects a bogus token)\r\n      \u001b[2minvalid token rejected via a JSON-RPC error inside HTTP 400 — safe, but the spec requires an HTTP 401 with WWW-Authenticate\u001b[0m\r\n      \u001b[36mfix:\u001b[0m Return HTTP 401 with `WWW-Authenticate: Bearer error=\"invalid_token\"` rather than a 2xx with a JSON-RPC error.\r\n  \u001b[32m✔\u001b[0m \u001b[2mE1       \u001b[0m \u001b[90mLOW     \u001b[0m Validates Origin header (DNS-rebinding defense)\r\n      \u001b[2mforeign Origin got 401 (rejected)\u001b[0m\r\n  \u001b[34mℹ\u001b[0m \u001b[2mE2       \u001b[0m \u001b[90mLOW     \u001b[0m Rejects GET on the MCP endpoint (2026-07-28)\r\n      \u001b[2mGET returned 401 — 2026-07-28 removed the GET stream, so 405 is expected\u001b[0m\r\n  \u001b[34mℹ\u001b[0m \u001b[2mA3       \u001b[0m \u001b[90mINFO    \u001b[0m WWW-Authenticate advertises scope (optional)\r\n      \u001b[2mno scope hint in challenge (optional per RFC 6750 §3)\u001b[0m\r\n\r\n  \u001b[32m2 pass\u001b[0m\u001b[2m · \u001b[0m\u001b[31m2 fail\u001b[0m\u001b[2m · \u001b[0m\u001b[33m1 warn\u001b[0m\u001b[2m · \u001b[0m\u001b[90m4 skip\u001b[0m\u001b[2m · \u001b[0m\u001b[2m0 error\u001b[0m\r\n"]
