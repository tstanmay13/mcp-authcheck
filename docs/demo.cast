[1.9,"o","\r\n\u001b[1mmcp-authcheck\u001b[0m \u001b[2mv0.1.0 · spec 2026-07-28\u001b[0m\r\n\u001b[2mtarget\u001b[0m  https://mcp.linear.app/mcp\r\n\r\n  \u001b[32m\u001b[1m  A  \u001b[0m\u001b[0m  \u001b[1m99/100\u001b[0m  \u001b[32mno failures\u001b[0m\r\n\r\n  \u001b[32m✔\u001b[0m \u001b[2mA1       \u001b[0m \u001b[31mCRITICAL\u001b[0m Rejects unauthenticated requests with 401\r\n      \u001b[2mserver challenges unauthenticated requests (via initialize)\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mA2       \u001b[0m \u001b[31mCRITICAL\u001b[0m 401 challenge advertises resource_metadata (RFC 9728 §5.1)\r\n      \u001b[2mchallenge advertises resource_metadata (https://mcp.linear.app/.well-known/oauth-protected-resource/mcp)\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mB1       \u001b[0m \u001b[31mCRITICAL\u001b[0m Protected Resource Metadata endpoint served\r\n      \u001b[2mPRM served at https://mcp.linear.app/.well-known/oauth-protected-resource/mcp\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mB3       \u001b[0m \u001b[31mCRITICAL\u001b[0m PRM authorization_servers non-empty\r\n      \u001b[2madvertises 1 authorization server(s)\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mC1[mcp.linear.app]\u001b[0m \u001b[31mCRITICAL\u001b[0m AS metadata discoverable via mandated fallback order\r\n      \u001b[2mdiscovered at https://mcp.linear.app/.well-known/oauth-authorization-server\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mD1       \u001b[0m \u001b[31mCRITICAL\u001b[0m Validates access tokens (rejects a bogus token)\r\n      \u001b[2minvalid token rejected with 401 (error=\"invalid_token\")\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mB2       \u001b[0m \u001b[33mHIGH    \u001b[0m PRM resource field present and canonical\r\n      \u001b[2mresource matches the server URI (https://mcp.linear.app/mcp)\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mC2[mcp.linear.app]\u001b[0m \u001b[33mHIGH    \u001b[0m AS metadata issuer exactly matches\r\n      \u001b[2missuer matches the advertised authorization server\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mC3[mcp.linear.app]\u001b[0m \u001b[33mHIGH    \u001b[0m AS metadata required fields present\r\n      \u001b[2mall required RFC 8414 fields present\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mC4[mcp.linear.app]\u001b[0m \u001b[33mHIGH    \u001b[0m PKCE S256 advertised\r\n      \u001b[2madvertises code_challenge_methods_supported containing S256\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mC5[mcp.linear.app]\u001b[0m \u001b[33mHIGH    \u001b[0m All AS endpoints served over HTTPS\r\n      \u001b[2mall advertised endpoints use https\u001b[0m\r\n  \u001b[33m▲\u001b[0m \u001b[2mC7[mcp.linear.app]\u001b[0m \u001b[90mLOW     \u001b[0m RFC 9207 issuer-response parameter supported\r\n      \u001b[2mdoes not advertise RFC 9207 iss support (SHOULD under 2026-07-28; mix-up defense, trending to MUST)\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mE1       \u001b[0m \u001b[90mLOW     \u001b[0m Validates Origin header (DNS-rebinding defense)\r\n      \u001b[2mforeign Origin got 401 (rejected)\u001b[0m\r\n  \u001b[34mℹ\u001b[0m \u001b[2mE2       \u001b[0m \u001b[90mLOW     \u001b[0m Rejects GET on the MCP endpoint (2026-07-28)\r\n      \u001b[2mGET returned 401 — 2026-07-28 removed the GET stream, so 405 is expected\u001b[0m\r\n  \u001b[34mℹ\u001b[0m \u001b[2mA3       \u001b[0m \u001b[90mINFO    \u001b[0m WWW-Authenticate advertises scope (optional)\r\n      \u001b[2mno scope hint in challenge (optional per RFC 6750 §3)\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mB4       \u001b[0m \u001b[90mINFO    \u001b[0m PRM recommended fields present\r\n      \u001b[2mpresent: scopes_supported, bearer_methods_supported; absent: resource_name, resource_documentation, jwks_uri, resource_signing_alg_values_supported, dpop_bound_access_tokens_required\u001b[0m\r\n  \u001b[32m✔\u001b[0m \u001b[2mC6[mcp.linear.app]\u001b[0m \u001b[90mINFO    \u001b[0m Client registration capability advertised\r\n      \u001b[2msupports CIMD (client_id_metadata_document_supported)\u001b[0m\r\n\r\n  \u001b[32m14 pass\u001b[0m\u001b[2m · \u001b[0m\u001b[2m0 fail\u001b[0m\u001b[2m · \u001b[0m\u001b[33m1 warn\u001b[0m\u001b[2m · \u001b[0m\u001b[90m0 skip\u001b[0m\u001b[2m · \u001b[0m\u001b[2m0 error\u001b[0m\r\n"]
